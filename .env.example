# ============================================================
# JWT Configuration (REQUIRED)
# Generate with: openssl rand -base64 32
# ============================================================
JWT_SECRET=your_secure_random_secret_here

# ============================================================
# CORS (REQUIRED in production)
# Comma-separated list of allowed frontend origins.
# Example: https://app.yourdomain.com
# Defaults to http://localhost:5173 if not set.
# ============================================================
ALLOWED_ORIGINS=https://yourdomain.com

# ============================================================
# Resend Email Service
# Sign up at https://resend.com and generate an API key
# ============================================================
RESEND_API_KEY=re_your_api_key_here

# ============================================================
# Application URL (used in invitation email links)
# ============================================================
APP_URL=https://yourdomain.com

# Email sender — must be a verified domain in Resend
FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Database — used by docker-compose.yml
# Generate strong credentials: openssl rand -base64 16
# Do NOT use the defaults below in production.
# ============================================================
POSTGRES_USER=screaming_toller_user
POSTGRES_PASSWORD=change_me_to_a_strong_random_password
POSTGRES_DB=screaming_toller

# Full DB URL (override if using an external/managed Postgres)
# DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?sslmode=require
