# Production Environment Template — Screaming Toller

# JWT Secret (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_random_secret_here

# CORS (REQUIRED in production)
# Comma-separated list of allowed frontend origins (your domain)
ALLOWED_ORIGINS=https://yourdomain.com

# Resend Email Service
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# Application URL (for invitation links)
APP_URL=https://yourdomain.com

# Database (Production Credentials)
# Generate strong passwords: openssl rand -base64 24
POSTGRES_USER=toller_prod_user
POSTGRES_PASSWORD=use_a_strong_random_password_here
POSTGRES_DB=screaming_toller_prod

# Database SSL Mode (Set to 'require' for production)
DB_SSLMODE=require

# Combined Database URL
DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?sslmode=${DB_SSLMODE}

# Cloudflare Turnstile (Captcha)
VITE_TURNSTILE_SITE_KEY=your_site_key
TURNSTILE_SECRET_KEY=your_secret_key

# Environment
ENV=production
